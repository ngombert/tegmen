# OpenRouter API Key (required)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Database Configuration (per agent, auto-configured in Docker)
DATABASE_URL=postgresql+asyncpg://tegmen:tegmen@localhost:5432/tegmen

# LLM Model (optional, defaults to gemini-2.0-flash)
DEFAULT_MODEL=openrouter/google/gemini-2.0-flash-001

# Embedding Model for Semantic Router (optional)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Microservices Mode (true = use A2A, false = local agents)
MICROSERVICES_MODE=false

# Debug mode (optional)
DEBUG=false
